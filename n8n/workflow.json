{
  "name": "Recruiting Agent MVP",
  "nodes": [
    {
      "name": "Email Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "httpMethod": "POST",
        "path": "recruiting-new-email"
      }
    },
    {
      "name": "Ingest Email",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/ingest-email",
        "sendBody": true,
        "jsonBody": "{\"max_results\": 10}"
      }
    },
    {
      "name": "Wait 48h",
      "type": "n8n-nodes-base.wait",
      "parameters": {
        "amount": 48,
        "unit": "hours"
      }
    },
    {
      "name": "Classify Candidate",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/classify",
        "sendBody": true,
        "jsonBody": "{\"candidate_id\": \"{{$json.id}}\"}"
      }
    },
    {
      "name": "Send Screening Email",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/send-screening",
        "sendBody": true,
        "jsonBody": "{\"candidate_id\": \"{{$json.id}}\"}"
      }
    },
    {
      "name": "Run Followups",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/followups/run",
        "sendBody": true,
        "jsonBody": "{\"reminder_after_hours\": 48, \"final_after_hours\": 96}"
      }
    }
  ],
  "connections": {
    "Email Webhook Trigger": {
      "main": [[{ "node": "Ingest Email", "type": "main", "index": 0 }]]
    },
    "Ingest Email": {
      "main": [[{ "node": "Wait 48h", "type": "main", "index": 0 }]]
    },
    "Wait 48h": {
      "main": [[{ "node": "Classify Candidate", "type": "main", "index": 0 }]]
    },
    "Classify Candidate": {
      "main": [[{ "node": "Send Screening Email", "type": "main", "index": 0 }]]
    },
    "Send Screening Email": {
      "main": [[{ "node": "Run Followups", "type": "main", "index": 0 }]]
    }
  }
}
